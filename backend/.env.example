# CogniFusion Backend Environment Variables
# Copy this to .env and fill in your actual Supabase credentials

# --- Server ---
PORT=5000
NODE_ENV=development

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- File Uploads ---
# Max file size in MB for MRI scans
MAX_MRI_FILE_SIZE=50
# Max file size in MB for audio
MAX_AUDIO_FILE_SIZE=20

# --- CORS ---
CLIENT_URL=http://localhost:5173
